[Unit]
Description=Smog Monitor Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/iot-smog-monitor/app
ExecStart=/usr/bin/python3 /opt/iot-smog-monitor/app/main.py
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
